<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Журнал звонков — CRM Автосервис</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0f1115;
            --bg-card: #161920;
            --bg-table: #1a1e24;
            --bg-table-hover: #222830;
            --bg-input: #1e232b;
            --text-primary: #e4e6eb;
            --text-secondary: #a0a3b1;
            --border-color: #2a2f38;
            --accent: rgb(255,135,24);
            --accent-hover: #2563eb;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        .crm-card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        .crm-header {
            background-color: var(--bg-card);
            border-bottom: 1px solid var(--border-color);
            padding: 1.25rem 1.5rem;
            border-radius: 12px 12px 0 0;
        }

        .crm-table {
            background-color: var(--bg-table);
            color: var(--text-primary);
            margin-bottom: 0;
        }

        .crm-table thead th {
            background-color: var(--bg-card);
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-color);
            padding: 1rem;
            white-space: nowrap;
        }

        .crm-table tbody td {
            border-bottom: 1px solid var(--border-color);
            padding: 0.875rem 1rem;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .crm-table tbody tr:hover {
            background-color: var(--bg-table-hover);
        }

        .filter-bar {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            gap: 1rem;
            align-items: end;
            flex-wrap: wrap;
        }

        .filter-group label {
            display: block;
            font-size: 0.75rem;
            color: var(--text-secondary);
            margin-bottom: 0.25rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .filter-group input[type="date"] {
            background-color: var(--bg-input);
            color: var(--text-primary);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 0.4rem 0.75rem;
            font-size: 0.9rem;
        }

        .filter-group input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(0.7);
        }

        .form-check-input {
            background-color: var(--bg-input);
            border-color: var(--border-color);
        }

        .form-check-input:checked {
            background-color: var(--accent);
            border-color: var(--accent);
        }

        .form-check-label {
            color: var(--text-primary);
            font-size: 0.9rem;
            cursor: pointer;
        }

        .btn-filter {
            background-color: var(--accent);
            border: none;
            color: #fff;
            padding: 0.45rem 1.25rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .btn-filter:hover {
            background-color: var(--accent-hover);
            color: #fff;
        }

        .btn-reset {
            background-color: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 0.45rem 1.25rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-reset:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }

        .btn-play {
            background-color: transparent;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            transition: all 0.2s;
        }

        .btn-play:hover {
            background-color: var(--accent);
            color: #fff;
        }

        .btn-preset {
            background-color: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 0.45rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .btn-preset:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }

        .btn-preset.active {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .pagination-bar {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .pagination-bar .info {
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .pagination-bar .pages {
            display: flex;
            gap: 0.35rem;
        }

        .pagination-bar .pages a,
        .pagination-bar .pages span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 36px;
            height: 36px;
            padding: 0 0.5rem;
            border-radius: 8px;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.15s;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            background-color: transparent;
        }

        .pagination-bar .pages a:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }

        .pagination-bar .pages .active {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .pagination-bar .pages .disabled {
            opacity: 0.4;
            cursor: default;
        }

        .badge-status {
            padding: 0.35em 0.75em;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 500;
            display: inline-block;
        }

        .status-success { background-color: rgba(34, 197, 94, 0.15); color: var(--success); }
        .status-missed  { background-color: rgba(239, 68, 68, 0.15); color: var(--danger); }
        .status-busy    { background-color: rgba(245, 158, 11, 0.15); color: var(--warning); }
        .status-default { background-color: rgba(160, 163, 177, 0.15); color: var(--text-secondary); }

        .type-icon {
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background-color: var(--bg-card);
        }

        .type-in { color: var(--success); }
        .type-out { color: var(--accent); }

        .text-muted-custom {
            color: var(--text-secondary) !important;
        }

        /* Стили для плеера */
        .audio-player-container {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: var(--bg-card);
            border-top: 1px solid var(--border-color);
            padding: 1rem;

        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 220px;
            height: 100vh;
            background-color: var(--bg-card);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem 1rem;
            z-index: 1000;
        }
        .sidebar .nav-link {
            color: var(--text-secondary);
            padding: 0.6rem 1rem;
            border-radius: 8px;
            margin-bottom: 0.25rem;
            display: block;
            text-decoration: none;
            transition: all 0.2s;
        }
        .sidebar .nav-link:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }
        .sidebar .nav-link.active {
            background-color: var(--accent);
            color: white;
        }
        .main-content {
            margin-left: 220px;
            padding: 1.5rem;
        }
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }

        .audio-player-container.show {
            transform: translateY(0);
        }

        .audio-info {
            display: flex;
            flex-direction: column;
            min-width: 0;
            flex-grow: 1;
        }

        .audio-title {
            font-weight: 500;
            margin-bottom: 0.25rem;
        }

        .audio-subtitle {
            color: var(--text-secondary);
            font-size: 0.85rem;
        }

        .audio-controls {
            display: flex;
            gap: 0.75rem;
            align-items: center;
        }

        .close-player {
            background-color: transparent;
            border: none;
            color: var(--text-secondary);
            font-size: 1.25rem;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
            transition: all 0.2s;
        }

        .close-player:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }

        body {
            padding-bottom: 1px;
        }

        /* Sidebar navigation */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 220px;
            height: 100vh;
            background-color: var(--bg-card);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem 1rem;
            z-index: 1000;
        }
        .sidebar .nav-link {
            color: var(--text-secondary);
            padding: 0.65rem 1rem;
            border-radius: 8px;
            margin-bottom: 0.25rem;
            display: block;
            text-decoration: none;
            transition: all 0.2s;
            font-size: 0.95rem;
        }
        .sidebar .nav-link:hover {
            background-color: var(--bg-table-hover);
            color: var(--text-primary);
        }
        .sidebar .nav-link.active {
            background-color: var(--accent);
            color: #fff;
        }
        .main-content {
            margin-left: 220px;
            padding: 1.5rem 2rem;
        }
    </style>
</head>
<body>

    <%- include('partials/sidebar', { currentPage: 'calls' }) %>

    <div class="main-content">
        <div class="container-fluid py-2 px-0">
            <div class="crm-card">
                <div class="crm-header">
                <div>
                    <h4 class="m-0 fw-bold">Журнал звонков</h4>
                </div>
            </div>

            <!-- Фильтры по дате -->
            <div class="filter-bar">
                <!-- Quick preset buttons -->
                <div class="d-flex gap-2 align-items-end flex-wrap me-3">
                    <a href="/calls?preset=today" class="btn-preset<%= preset === 'today' ? ' active' : '' %>">Сегодня</a>
                    <a href="/calls?preset=yesterday" class="btn-preset<%= preset === 'yesterday' ? ' active' : '' %>">Вчера</a>
                    <a href="/calls?preset=week" class="btn-preset<%= preset === 'week' ? ' active' : '' %>">Неделя</a>
                    <a href="/calls?preset=month" class="btn-preset<%= preset === 'month' ? ' active' : '' %>">Месяц</a>
                </div>

                <form method="GET" action="/calls" class="d-flex gap-3 align-items-end flex-wrap">
                    <input type="hidden" name="preset" value="">
                    <div class="filter-group">
                        <label for="dateFrom">С</label>
                        <input type="date" id="dateFrom" name="dateFrom" value="<%= dateFrom %>">
                    </div>
                    <div class="filter-group">
                        <label for="dateTo">По</label>
                        <input type="date" id="dateTo" name="dateTo" value="<%= dateTo %>">
                    </div>
                    <div class="filter-group">
                        <label for="firstTime" class="form-check-label d-flex align-items-center">
                            <input type="checkbox" id="firstTime" name="firstTime" class="form-check-input me-2" <%= (firstTime === 'on') ? 'checked' : '' %>>
                            Звонили в первый раз
                        </label>
                    </div>
                    <div class="filter-group">
                        <button type="submit" class="btn-filter">Применить</button>
                    </div>
                    <div class="filter-group">
                        <a href="/calls" class="btn-reset">Сбросить</a>
                    </div>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table crm-table">
                    <thead>
                        <tr>
                            <th>Тип</th>
                            <th>Статус</th>
                            <th>Дата / Время</th>
                            <th>Телефон клиента</th>
                            <th>Номер назначения</th>
                            <th>Имя клиента</th>
                            <th>Авто</th>
                            <th>Длительность</th>
                            <th>Запись</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (calls && calls.length > 0) { %>
                            <% calls.forEach(function(call) { %>
                                <tr>
                                    <td>
                                        <span class="type-icon <%= call.type === 'in' ? 'type-in' : 'type-out' %>" title="<%= call.type === 'in' ? 'Входящий' : 'Исходящий' %>">
                                            <%= call.type === 'in' ? '📥' : '📤' %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if (call.status === 'Success') { %>
                                            <span class="badge-status status-success">Принят</span>
                                        <% } else if (call.status === 'Missed') { %>
                                            <span class="badge-status status-missed">Пропущенный</span>
                                        <% } else if (call.status === 'Busy') { %>
                                            <span class="badge-status status-busy">Занят</span>
                                        <% } else if (call.status === 'Cancel') { %>
                                            <span class="badge-status status-default">Отменён</span>
                                        <% } else if (call.status === 'NotAvailable') { %>
                                            <span class="badge-status status-default">Недоступен</span>
                                        <% } else if (call.status === 'NotAllowed') { %>
                                            <span class="badge-status status-default">Запрещён</span>
                                        <% } else if (call.status === 'NotFound') { %>
                                            <span class="badge-status status-default">Не найден</span>
                                        <% } else { %>
                                            <span class="badge-status status-default"><%= call.status || '—' %></span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (call.start_time) {
                                            var d = new Date(call.start_time);
                                            var dateStr = d.toLocaleDateString('ru-RU');
                                            var timeStr = d.toLocaleTimeString('ru-RU', {hour:'2-digit', minute:'2-digit'});
                                        %>
                                            <div><%= dateStr %></div>
                                            <small class="text-muted-custom"><%= timeStr %></small>
                                        <% } else { %>
                                            —
                                        <% } %>
                                    </td>
                                    <td><%= call.client_phone || '—' %></td>
                                    <td><%= call.diversion || '—' %></td>
                                    <td><%= call.client_name || '—' %></td>
                                    <td><%= call.car_number || '—' %></td>

                                    <td>
                                        <% if (call.duration > 0) {
                                            var min = Math.floor(call.duration / 60);
                                            var sec = call.duration % 60;
                                        %>
                                            <%= min %>:<%= String(sec).padStart(2, '0') %>
                                        <% } else { %>
                                            <span class="text-muted-custom">—</span>
                                        <% } %>
                                    </td>
                                     <td>
                                         <% if (call.status !== 'Missed') { %>
                                             <button class="btn-play" onclick="playRecording('<%= call.id %>', '<%= call.client_phone || "Неизвестный" %>', '<%= call.client_name || "—" %>')">
                                                 ▶️ Прослушать
                                             </button>
                                         <% } else { %>
                                             <span class="text-muted-custom">—</span>
                                         <% } %>
                                     </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="10" class="text-center text-muted-custom py-5">
                                    Звонков не найдено. Попробуйте изменить фильтры или синхронизировать данные.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pagination-bar">
                <div class="info">
                    Всего <%= totalCount %> записей — страница <%= page %> из <%= totalPages %>
                </div>
                <div class="pages">
                    <% if (page > 1) { %>
                        <a href="<%= '/calls?page=' + (page - 1) + (preset ? '&preset=' + preset : '') + (dateFrom ? '&dateFrom=' + dateFrom : '') + (dateTo ? '&dateTo=' + dateTo : '') %>">←</a>
                    <% } else { %>
                        <span class="disabled">←</span>
                    <% } %>

                    <% 
                    var startPage = Math.max(1, page - 2);
                    var endPage = Math.min(totalPages, page + 2);
                    if (startPage > 1) { %>
                        <a href="<%= '/calls?page=1' + (preset ? '&preset=' + preset : '') + (dateFrom ? '&dateFrom=' + dateFrom : '') + (dateTo ? '&dateTo=' + dateTo : '') %>">1</a>
                        <% if (startPage > 2) { %><span class="disabled">…</span><% } %>
                    <% } %>
                    <% for (var p = startPage; p <= endPage; p++) { %>
                        <% if (p === page) { %>
                            <span class="active"><%= p %></span>
                        <% } else { %>
                            <a href="<%= '/calls?page=' + p + (preset ? '&preset=' + preset : '') + (dateFrom ? '&dateFrom=' + dateFrom : '') + (dateTo ? '&dateTo=' + dateTo : '') %>"><%= p %></a>
                        <% } %>
                    <% } %>
                    <% if (endPage < totalPages) { %>
                        <% if (endPage < totalPages - 1) { %><span class="disabled">…</span><% } %>
                        <a href="<%= '/calls?page=' + totalPages + (preset ? '&preset=' + preset : '') + (dateFrom ? '&dateFrom=' + dateFrom : '') + (dateTo ? '&dateTo=' + dateTo : '') %>"><%= totalPages %></a>
                    <% } %>

                    <% if (page < totalPages) { %>
                        <a href="<%= '/calls?page=' + (page + 1) + (preset ? '&preset=' + preset : '') + (dateFrom ? '&dateFrom=' + dateFrom : '') + (dateTo ? '&dateTo=' + dateTo : '') %>">→</a>
                    <% } else { %>
                        <span class="disabled">→</span>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Прилипающий аудиоплеер -->
    <div id="audioPlayer" class="audio-player-container">
        <div class="audio-info">
            <div id="audioTitle" class="audio-title">Загрузка...</div>
            <div id="audioSubtitle" class="audio-subtitle">...</div>
        </div>
        <div class="audio-controls">
            <audio id="audioElement" controls style="height: 40px;"></audio>
            <button class="close-player" onclick="closePlayer()">✕</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function playRecording(callId, phone, name) {
            const player = document.getElementById('audioPlayer');
            const audioElement = document.getElementById('audioElement');
            const titleElement = document.getElementById('audioTitle');
            const subtitleElement = document.getElementById('audioSubtitle');
            
            // Установка информации о звонке
            titleElement.textContent = `Звонок от: ${name}`;
            subtitleElement.textContent = `Телефон: ${phone} | ID: ${callId}`;
            
            // Установка источника аудио
            audioElement.src = `/api/calls/recording/${callId}`;
            
            // Показать плеер с анимацией
            setTimeout(() => {
                player.classList.add('show');
                audioElement.play().catch(e => {
                    console.error('Ошибка воспроизведения:', e);
                    alert('Не удалось воспроизвести запись разговора');
                });
            }, 100);
            
            // Добавление отступа к body для открытия пространства
            document.body.style.paddingBottom = '100px';
        }
        
        function closePlayer() {
            const player = document.getElementById('audioPlayer');
            const audioElement = document.getElementById('audioElement');
            
            // Остановка воспроизведения
            audioElement.pause();
            audioElement.src = '';
            
            // Скрыть плеер с анимацией
            player.classList.remove('show');
            
            // Удаление отступа
            document.body.style.paddingBottom = '1px';
        }
        
        // Обработка событий для автоматического закрытия плеера
        document.getElementById('audioElement').addEventListener('ended', function() {
            setTimeout(closePlayer, 2000); // Закрыть через 2 секунды после окончания
        });
                });
                console.log('Response received:', response.status);
                
                const result = await response.json();
                console.log('Response from server:', result);
                
                if (response.ok) {
                    cleanText.textContent = `Удалено: ${result.deleted}`;
                    cleanBtn.classList.remove('btn-outline-secondary');
                    cleanBtn.classList.add('btn-success');
                    
                    // Сразу перезагружаем страницу с принудительным обновлением кэша
                    window.location.reload(true);
                } else {
                    cleanText.textContent = 'Ошибка';
                    cleanBtn.classList.remove('btn-outline-secondary');
                    cleanBtn.classList.add('btn-danger');
                    
                    setTimeout(() => {
                        cleanText.textContent = 'Очистить дубликаты';
                        cleanBtn.classList.remove('btn-danger');
                        cleanBtn.classList.add('btn-outline-secondary');
                        cleanBtn.disabled = false;
                        cleanSpinner.classList.add('d-none');
                    }, 2000);
                }
            } catch (error) {
                console.error('Error cleaning duplicates:', error);
                cleanText.textContent = 'Ошибка соединения';
                cleanBtn.classList.remove('btn-outline-secondary');
                cleanBtn.classList.add('btn-danger');
                
                setTimeout(() => {
                    cleanText.textContent = 'Очистить дубликаты';
                    cleanBtn.classList.remove('btn-danger');
                    cleanBtn.classList.add('btn-outline-secondary');
                    cleanBtn.disabled = false;
                    cleanSpinner.classList.add('d-none');
                }, 2000);
            }
        }
    </script>
        </div>
    </div>
</body>
</html>
